{
  "name": "volcanic-musicplayer",
  "version": "1.1.0",
  "description": "A high-performance media asset manager and proprietary container stream recovery tool.",
  "main": "out/main/index.js",
  "type": "commonjs",
  "scripts": {
    "dev": "electron-vite dev --watch",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p src/renderer/tsconfig.json && tsc --noEmit -p src/main/tsconfig.json",
    "pack": "node scripts/pack.cjs --dir",
    "dist": "node scripts/pack.cjs"
  },
  "keywords": [
    "electron",
    "react",
    "vite",
    "typescript",
    "audio-converter"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "lamejs": "^1.2.1",
    "lucide-react": "^1.21.0"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  },
  "build": {
    "appId": "com.volcanic.musicplayer",
    "productName": "Volcanic mvp v1.1",
    "executableName": "Volcanic mvp v1.1",
    "artifactName": "Volcanic mvp v1.1.${ext}",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "build/icon.png",
      "node_modules/lamejs/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
